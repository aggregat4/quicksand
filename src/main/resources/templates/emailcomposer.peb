<!DOCTYPE html>
<html lang="en">
<head>
    {% import "templates/macros.peb" %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Mail Composer - Quicksand</title>
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/emailcomposer.css">
</head>
<body class="email-composer" data-draft-id="{{ draft.id() }}">
    <main>
        <form id="save-email-form" method="POST" enctype="multipart/form-data" action="/emails/{{ draft.id() }}">
            {# Note that this div must be empty when no validation errors since the CSS selects on :empty #}
            <div id="validation-errors"  class="validation-errors">{% if validationErrors != null %}{{ validationErrors }}{% endif %}</div>

            <label for="email-to">To:</label>
            <input id="email-to" type="text" name="email-to" value="{{ draft.to() }}">

            <label for="email-cc">CC:</label>
            <input id="email-cc" type="text" name="email-cc" value="{{ draft.cc() }}">

            <label for="email-bcc">BCC:</label>
            <input id="email-bcc" type="text" name="email-bcc" value="{{ draft.bcc() }}">

            <label for="email-subject">Subject:</label>
            <input id="email-subject" type="text" name="email-subject" value="{{ draft.subject() }}">

            <div id="body-with-attachments">
                {# This is the simplest way I could find for making a text area grow in vertical size so that it
                   does not become a scrollable rectangle. We want this because we want the attachments to hang to the
                   bottom of the body of the email and not take up vertical space in the editor itself.
                   See https://css-tricks.com/the-cleanest-trick-for-autogrowing-textareas/
                   #}
                <div id="email-body-grow-wrap" class="grow-wrap">
                    <textarea
                            id="email-body"
                            name="email-body"
                            aria-label="Email Body"
                            onInput="this.parentNode.dataset.replicatedValue = this.value">{{ draft.body() }}</textarea>
                </div>
                <div id="attachments">
                    {% if attachments.isEmpty() %}
                        <div id="no-draft-attachments">No attachments yet</div>
                    {% else %}
                        <div id="draft-attachments">
                            <div>Attachments:</div>
                            <ul>
                                {% for attachment in attachments %}
                                    <li>
                                        <a class="attachment" href="/attachments/{{ attachment.id }}" target="_blank">{{ attachment.name }}</a>,
                                        {{ attachment.sizeInBytes / 1024 }}KB,
                                        {{ attachment.mediaType }}
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div id="email-toolbar">
                {{ submitButton(true, 'send', false, 'email-action-send', 'Send Email') }}
                {{ submitButton(true, 'delete', false, 'email-action-delete', 'Delete Draft') }}
                {{ submitButton(true, 'add', false, 'email-action-send', 'Add Attachment', type = 'button', classes = 'add-attachment-button') }}
            </div>
        </form>
        <form id="autosave-email-form" method="POST" action="/emails/{{ draft.id() }}/draft" target="draftsaveframe" hidden>
            <input type="hidden" name="email-to">
            <input type="hidden" name="email-cc">
            <input type="hidden" name="email-bcc">
            <input type="hidden" name="email-subject">
            <input type="hidden" name="email-body">
        </form>
        <iframe id="draftsaveframe" name="draftsaveframe" hidden></iframe>
        <form id="attachment-upload-form" method="POST" enctype="multipart/form-data" action="/emails/{{ draft.id() }}/attachments">
            <input id="attachment-upload-input" type="file" name="uploaded-file" multiple hidden>
        </form>
    </main>
    <script src="/js/emailcomposer.js"></script>
</body>
</html>
