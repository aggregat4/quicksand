<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Mail Viewer - Quicksand</title>
    <link rel="stylesheet" href="{{ asset('/css/base.css') }}">
    <link rel="stylesheet" href="{{ asset('/css/emailviewer.css') }}">
</head>
<body class="emailviewer" data-email-id="{{ email.header.id }}">
    {% import "templates/macros.peb" %}
    <main>
        <div id="emailsubject">
            <h1>{{ highlightText(email.header.subject, currentQuery.orElse('')) | raw }}</h1>
        </div>
        {% if outboundStatus %}
            <div id="emailstatus">
                <strong>{{ outboundStatus }}</strong>
                {% if outboundStatusDetail %} - {{ outboundStatusDetail }}{% endif %}
            </div>
        {% endif %}
        <div id="emailmetadata">
            <div id="from">
                From: {{ highlightedActor(email.header.getSender(), currentQuery.orElse('')) }}
            </div>
            <div id="receiveddate">
                {% if (email.attachments != null) and (not email.attachments.isEmpty()) %}
                    <div id="attachment">
                            {{ svgIcon('attachment') | raw }}
                    </div>
                {% endif %}
                {{ email.header.longFormattedReceivedDate() }}
            </div>
            <div id="to">
                To: {{ highlightedActorList(email.header.getRecipients(), currentQuery.orElse('')) }}
            </div>
            {% if not email.header.getBCCRecipients().isEmpty() %}
                <div id="bcc">
                    BCC: {{ highlightedActorList(email.header.getBCCRecipients(), currentQuery.orElse('')) }}
                </div>
            {% endif %}
            {% if not email.header.getCCRecipients().isEmpty() %}
                <div id="cc">
                    CC: {{ highlightedActorList(email.header.getCCRecipients(), currentQuery.orElse('')) }}
                </div>
            {% endif %}
        </div>
        <div id="emailactions">
            {% if readOnly != true %}
            <div id="emailreplyforward">
                    {{ submitButton(true, 'reply', false, 'reply_email', 'Reply') }}
                    {{ submitButton(true, 'reply', false, 'forward_email', 'Forward') }}
            </div>
            {% endif %}
        </div>
        {% if not email.plainText %}
            <a id="emailimages" href="/emails/{{ email.header.id }}/viewer?showImages={{ showImages ? 'false' : 'true' }}{% if currentQuery.isPresent() %}&query={{ currentQuery.get() | urlencode }}{% endif %}">
                {% if showImages %}Disable Images{% else %}Enable Images{% endif %}
            </a>
        {% endif %}
        <div id="emailbody">
            {% if email.plainText %}
                <pre>{{ highlightText(email.body, currentQuery.orElse('')) | raw }}</pre>
            {% else %}
                <iframe id="emailbodyframe"
                        src="/emails/{{ email.header.id }}/viewer/body?showImages={{ showImages ? 'true' : 'false' }}{% if currentQuery.isPresent() %}&query={{ currentQuery.get() | urlencode }}{% endif %}"
                        sandbox="allow-same-origin"
                ></iframe>
            {% endif %}
        </div>
        <div id="emailattachments">
            {% if not email.attachments.isEmpty() %}
                Attachments:
                <ul>
                {% for attachment in email.attachments %}
                    <li><a class="attachment" href="/attachments/{{ attachment.id }}">{{ (attachment.name != null and attachment.name != "") ? attachment.name : 'attachment without name' }}</a>, {{ attachment.sizeInBytes / 1024 }}KB, {{ attachment.mediaType }}</li>
                {% endfor %}
                </ul>
            {% else %}
                No attachments
            {% endif %}
        </div>
        <div id="emailbottomactions">
            {# some actions, maybe just reply? #}
        </div>
    </main>

    <script type="importmap">{{ importMap() | raw }}</script>
    <script type="module" src="{{ asset('/js/iframe/viewer.js') }}"></script>
</body>
</html>
